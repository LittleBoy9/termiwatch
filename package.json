{
  "name": "termiwatch",
  "version": "1.0.0",
  "description": "Zero-config, one-line terminal dashboard for Node.js apps. Real-time CPU, memory, event loop, HTTP metrics, and logs.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./auto": {
      "types": "./dist/auto.d.ts",
      "require": "./dist/auto.js",
      "import": "./dist/auto.js"
    }
  },
  "bin": {
    "termiwatch": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --test test/*.test.js",
    "pretest": "npm run build",
    "prepublishOnly": "npm run build",
    "example": "npm run build && node examples/demo.js"
  },
  "keywords": [
    "monitor",
    "monitoring",
    "dashboard",
    "terminal",
    "cli",
    "metrics",
    "cpu",
    "memory",
    "event-loop",
    "performance",
    "devtools",
    "nodejs",
    "real-time",
    "zero-config",
    "zero-dependency",
    "http",
    "gc",
    "heap",
    "profiler",
    "process-monitor",
    "express",
    "fastify",
    "nestjs",
    "worker-threads",
    "observability"
  ],
  "author": "Sounak Das (https://sounakdas.in)",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "homepage": "https://littleboy9.github.io/termiwatch",
  "repository": {
    "type": "git",
    "url": "https://github.com/LittleBoy9/termiwatch.git"
  },
  "bugs": {
    "url": "https://github.com/LittleBoy9/termiwatch/issues"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
